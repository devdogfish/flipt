// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum ReviewResult {
  FORGOT
  HARD
  GOOD
  EASY
}

enum Role {
  USER
  ADMIN
}

enum DeckType {
  PERSONAL
  COURSE
}

enum SuggestionType {
  ADD
  EDIT
  DELETE
}

enum SuggestionStatus {
  PENDING
  MERGED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  decks            Deck[]
  settings         UserSettings?
  usage            FlashcardUsage[]
  favorites        DeckFavorite[]
  sharedDecks      DeckShare[]
  apiKeys          ApiKey[]
  schedules        CardSchedule[]
  collections      Collection[]
  suggestions      CardSuggestion[]
  suggestionFlags  SuggestionFlag[]
  cardFlags        CardFlag[]
  role             Role              @default(USER)
  emailVerified    Boolean           @default(false)
  image            String?
  updatedAt        DateTime          @updatedAt
  sessions         Session[]
  accounts         Account[]
  dalEmail         String?           @unique
  dalVerification  DalVerification?
  fieldOfStudy     String?

  @@map("user")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  key       String    @unique
  createdAt DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model UserSettings {
  id               String @id @default(cuid())
  userId           String @unique
  theme            Theme  @default(SYSTEM)
  desiredRetention Float  @default(0.9)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deck {
  id          String     @id @default(cuid())
  ownerId     String?
  title       String
  description String?
  coverImage  String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deckType    DeckType   @default(PERSONAL)
  courseCode  String?

  owner       User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  cards       Flashcard[]
  favorites   DeckFavorite[]
  shares      DeckShare[]
  collections CollectionDeck[]
  suggestions CardSuggestion[]

  @@index([ownerId])
  @@index([visibility])
  @@index([courseCode])
}

model Collection {
  id         String   @id @default(cuid())
  userId     String
  name       String
  courseCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks CollectionDeck[]

  @@unique([courseCode])
  @@index([userId])
}

model CollectionDeck {
  collectionId String
  deckId       String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  deck       Deck       @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([collectionId, deckId])
  @@index([deckId])
}

model DeckShare {
  deckId    String
  userId    String
  createdAt DateTime @default(now())

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([deckId, userId])
  @@index([userId])
}

model DeckFavorite {
  userId    String
  deckId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([userId, deckId])
  @@index([userId])
}

model Flashcard {
  id        String   @id @default(cuid())
  deckId    String
  question  String
  answer    String
  imageUrl  String?
  position  Int      @default(0)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deck      Deck             @relation(fields: [deckId], references: [id], onDelete: Cascade)
  usage     FlashcardUsage[]
  schedules CardSchedule[]
  flags     CardFlag[]

  @@index([deckId, position])
}

model FlashcardUsage {
  id         String       @id @default(cuid())
  userId     String
  cardId     String
  result     ReviewResult
  reviewedAt DateTime     @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt])
  @@index([userId, cardId])
}

model CardSchedule {
  id             String    @id @default(cuid())
  userId         String
  cardId         String
  stability      Float
  difficulty     Float
  nextDue        DateTime
  reviewCount    Int       @default(0)
  lastReviewedAt DateTime?

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, nextDue])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model DalVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  dalEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Community deck models
// ---------------------------------------------------------------------------

model CardSuggestion {
  id           String           @id @default(cuid())
  deckId       String
  suggestorId  String
  type         SuggestionType
  targetCardId String?
  question     String?
  answer       String?
  status       SuggestionStatus @default(PENDING)
  aiApproved   Boolean          @default(true)
  mergeAt      DateTime
  createdAt    DateTime         @default(now())

  deck      Deck             @relation(fields: [deckId], references: [id], onDelete: Cascade)
  suggestor User             @relation(fields: [suggestorId], references: [id], onDelete: Cascade)
  flags     SuggestionFlag[]

  @@index([deckId, status])
  @@index([mergeAt, status])
}

model SuggestionFlag {
  suggestionId String
  userId       String
  createdAt    DateTime @default(now())

  suggestion CardSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([suggestionId, userId])
}

model CardFlag {
  id        String    @id @default(cuid())
  cardId    String
  userId    String
  reason    String?
  createdAt DateTime  @default(now())

  card Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([cardId])
}

