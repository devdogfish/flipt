{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:start": "docker start flashcardbrowser-db 2>/dev/null || docker run --name flashcardbrowser-db -e POSTGRES_HOST_AUTH_METHOD=trust -e POSTGRES_USER=postgres -e POSTGRES_DB=flashcardbrowser -p 5432:5432 -d postgres",
    "db:stop": "docker stop flashcardbrowser-db",
    "db:seed": "bun run prisma/seed.ts",
    "db:reset": "bunx prisma db push --force-reset && bun run prisma/seed.ts",
    "db:reset:production": "vercel env pull .env.local --environment=production && export $(grep '^DATABASE_URL' .env.local | xargs) && bunx prisma db push --force-reset && NODE_NO_WARNINGS=1 bun run prisma/seed.ts"
  },
