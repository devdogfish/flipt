# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres@localhost:5432/flashcardbrowser-db"

# Better Auth
BETTER_AUTH_SECRET=""        # Generate with: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=""

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=""

# OpenRouter — AI flashcard generation (https://openrouter.ai/keys)
OPENROUTER_API_KEY=""

# Google AI / Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# Pixazo — image generation (https://api-console.pixazo.ai/)
PIXAZO_API_KEY=""

# Cloudflare Workers AI — LLM + image fallback (https://dash.cloudflare.com → AI → Workers AI)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Cron job auth (Vercel sets this automatically; generate with: openssl rand -hex 32)
CRON_SECRET=""
